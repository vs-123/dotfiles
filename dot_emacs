;;  UI & COSMETICS  ;;
;;;;;;;;;;;;;;;;;;;;;;

(set-frame-font "Menlo 16")
(my/pkg-i 'royal-hemlock-theme)
(load-theme 'royal-hemlock t)

(menu-bar-mode 0)
(scroll-bar-mode 0)
(column-number-mode 1)
(indent-tabs-mode 0)
(tab-bar-mode t)
(global-hl-line-mode t)
(global-display-line-numbers-mode t)

(setq inhibit-startup-screen 1
      display-line-numbers-type 'relative)

(my/spam-greet)

;;;;;;;;;;;;;;;;;;;;;;;;
;;  EDITOR BEHAVIOUR  ;;
;;;;;;;;;;;;;;;;;;;;;;;;

(defalias 'yes-or-no-p 'y-or-n-p)

(setq backup-inhibited t
      c-basic-offset 3
      c-ts-mode-indent-offset 3
      case-replace nil
      mouse-wheel-scroll-amount 3
      next-screen-context-lines 10
      scroll-conservatively 101
      scroll-margin 3
      tab-width 3
      word-wrap t
      package-archive-zip-program '("gtar" "-z" "--no-same-owner")
      org-startup-truncated nil
      word-wrap t)

;;;;;;;;;;;;;;;;;;;;;;;;;
;;  KEYBINDS & ADVICE  ;;
;;;;;;;;;;;;;;;;;;;;;;;;;

(advice-add 'next-line :around #'my/logical-line-on-prefix)
(advice-add 'previous-line :around #'my/logical-line-on-prefix)

(global-set-key (kbd "M-,") 'tab-bar-switch-to-prev-tab)
(global-set-key (kbd "M-.") 'tab-bar-switch-to-next-tab)
(global-set-key (kbd "C-x C-p") 'previous-line)
(global-set-key (kbd "C-x C-n") 'next-line)
(global-set-key (kbd "C-x f") 'find-file)
(global-set-key (kbd "C-x C-h") 'mark-whole-buffer)
(global-set-key (kbd "C-h C-k") 'describe-key)
(global-set-key (kbd "C-x s") 'save-buffer)
(global-set-key (kbd "C-z") nil)

(put 'upcase-region 'disabled nil)
(put 'downcase-region 'disabled nil)

