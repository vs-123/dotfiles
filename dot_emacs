(defun my/rand-str (len)
   (let ((chars "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789")
         (result ""))
      (dotimes (_ len result)
         (let ((idx (random (length chars))))
            (setq result (concat result (substring chars idx (1+ idx))))))))

(defun my/spam-greet ()
   (let* ((len (+ 333 (random 333)))
          (magic (my/rand-str len)))
      (setq initial-scratch-message (format ";; %s\n\n" magic))
      (setq inhibit-startup-echo-area-message (user-login-name))
      (add-hook 'emacs-startup-hook `(lambda () (message "%s" ,magic)))))

(my/spam-greet)

