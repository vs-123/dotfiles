;;  PACKAGES & HELPER FUNCTIONS  ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(setq package-archives
      '(("gnu" . "https://elpa.gnu.org/packages/")
	("melpa" . "https://melpa.org/packages/")))

(package-initialize)

(defun my/pkg-i (pkg)
  "Adds package `pkg`"
  (unless (package-installed-p pkg)
    (package-install pkg)))

(defun my/rand-str (len)
   (let ((chars "1234567890")
         (result ""))
      (dotimes (_ len result)
         (let ((idx (random (length chars))))
            (setq result (concat result (substring chars idx (1+ idx))))))))

(defun my/logical-line-on-prefix (orig-fun &rest args)
  "Use logical line movement when C-u is used"
  (let ((line-move-visual (if current-prefix-arg nil line-move-visual)))
    (apply orig-fun args)))

(defun my/spam-greet ()
   (let* ((len (+ 333 (random 333)))
          (magic (my/rand-str len)))
      (setq initial-scratch-message (format ";; %s\n\n" magic))
      (setq inhibit-startup-echo-area-message (user-login-name))
  ;   (add-hook 'emacs-startup-hook `(lambda () (message "%s" ,magic)))
      ))

