(defun my/logical-line-on-prefix (orig-fun &rest args)
  "Use logical line movement when C-u is used"
  (let ((line-move-visual (if current-prefix-arg nil line-move-visual)))
    (apply orig-fun args)))

(advice-add 'next-line :around #'my/logical-line-on-prefix)
(advice-add 'previous-line :around #'my/logical-line-on-prefix)

